# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789,987654321
SUPERADMIN_ID=123456789

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/kingstore
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/kingstore

# Redis
REDIS_URL=redis://redis:6379/0

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id
GOOGLE_CREDENTIALS_JSON=path/to/credentials.json
GOOGLE_SYNC_INTERVAL_MINUTES=5

# LiveSklad
LIVESKLAD_API_LOGIN=your_livesklad_api_login
LIVESKLAD_API_PASSWORD=your_livesklad_api_password
LIVESKLAD_SHOP_ID=your_shop_id
LIVESKLAD_TYPE_ORDER_ID=your_type_order_id
LIVESKLAD_BASE_URL=https://api.livesklad.com

# Webhook (for production)
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=random_secret_string

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
